PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Connection Topology (Routes directly to your Docker Postgres Container)
DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=multiwallet

# Queue Configuration
REDIS_URL=redis://127.0.0.1:6379

# LLM Core Settings
USE_REAL_LLM=false
LLM_PROVIDER=GEMINI
LLM_API_KEY=AIzaSyDLlJtmjUKVtwFpJa9cIpVijVK_8oYUJjE
LLM_MAX_CONCURRENT=2
LLM_RESERVOIR=60
LLM_RESERVOIR_REFRESH=60
LLM_RESERVOIR_INTERVAL_MS=60000
LLM_MIN_TIME_MS=50
LLM_TIMEOUT_MS=15000
LLM_RETRIES=3